DEBUG=true
ENVIRONMENT=development

DATABASE_URL=postgresql+asyncpg://username:password@localhost:5432/quorum_db
# Set true only when debugging SQL (otherwise logs stay quiet even if DEBUG=true).
DATABASE_ECHO=false

# JWT signing (required in production — use a long random secret)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=7

# Optional: skip inbox step locally (marks email verified immediately)
AUTH_DEV_AUTO_VERIFY_EMAIL=false

# Frontend links in transactional emails
FRONTEND_APP_BASE_URL=http://localhost:5173

# Email (optional — without MAILTRAP_API_TOKEN, messages are logged only)
MAILTRAP_API_TOKEN=
MAIL_FROM_EMAIL=noreply@example.com
MAIL_FROM_NAME=Quorum

# Feature APIs (optional)
OPENAI_API_KEY=your-openai-api-key
GROQ_API_KEY=your-groq-api-key

# Rate limits (SlowAPI; per-IP). Set RATE_LIMITS_ENABLED=false to disable checks.
RATE_LIMITS_ENABLED=true
# RATE_LIMIT_AUTH_REGISTER=10/minute
# RATE_LIMIT_AUTH_LOGIN=20/minute
# RATE_LIMIT_AUTH_REFRESH=30/minute
# RATE_LIMIT_AUTH_VERIFY=30/minute
# RATE_LIMIT_AUTH_FORGOT_PASSWORD=5/minute
# RATE_LIMIT_AUTH_RESET_PASSWORD=10/minute
# RATE_LIMIT_AUTH_LOGOUT=30/minute

