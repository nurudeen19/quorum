# Copy this file to .env and adjust values.

# Database (required for API + migrations)
DATABASE_URL=postgresql+asyncpg://username:password@localhost:5432/quorum_db

# JWT signing (required in production — use a long random secret)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=7

# Email verification / password reset token lifetimes
EMAIL_VERIFICATION_EXPIRE_HOURS=48
PASSWORD_RESET_EXPIRE_MINUTES=60

# Optional: skip inbox step locally (marks email verified immediately)
AUTH_DEV_AUTO_VERIFY_EMAIL=false

# Frontend links in transactional emails
FRONTEND_APP_BASE_URL=http://localhost:5173

# Email (optional — without MAILTRAP_API_TOKEN, messages are logged only)
MAILTRAP_API_TOKEN=
MAIL_FROM_EMAIL=noreply@example.com
MAIL_FROM_NAME=Quorum

# Feature APIs (optional)
OPENAI_API_KEY=your-openai-api-key
GROQ_API_KEY=your-groq-api-key

DEBUG=true
ENVIRONMENT=development
